# FastAPI 服务监听端口。
PORT=8000

# Nacos 地址；生产环境改成真实 Nacos 地址。
NACOS_BASE_URL=http://127.0.0.1:8848/nacos

# Nacos 2.x / 2.5.1 使用 v1；Nacos 3.x 使用 v3。
NACOS_API_VERSION=v1

# Nacos 开启鉴权时填写；未开启鉴权时可留空。
NACOS_USERNAME=
NACOS_PASSWORD=

# 允许访问后端的前端地址，8083 是当前保留的 Vue + Vite 前端入口。
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://localhost:8083

# 发布 Nacos 配置接口的服务端密钥，生产环境必须改强密码。
PUBLISH_API_KEY=change-this-to-a-strong-key

# 硬件未接入时启用状态机模拟器。
USE_STATE_MACHINE_SIMULATOR=true
SIMULATOR_AUTO_TICK=true
SIMULATOR_TICK_SECONDS=5

# 打开后，Python 模拟器会把硬件快照写入 Nacos。
SIMULATOR_NACOS_SYNC_ENABLED=true
SIMULATOR_NACOS_SYNC_INTERVAL_TICKS=1
SIMULATOR_NACOS_DATA_ID=factory.hardware.snapshot.json
SIMULATOR_NACOS_GROUP=DEFAULT_GROUP
SIMULATOR_NACOS_TENANT=

# FastAPI 默认从 Nacos 读取设备状态，再统一返回给前端大屏。
DEVICE_STATUS_SOURCE=nacos
DEVICE_STATUS_NACOS_DATA_ID=factory.hardware.snapshot.json
DEVICE_STATUS_NACOS_GROUP=DEFAULT_GROUP
DEVICE_STATUS_NACOS_TENANT=
DEVICE_STATUS_NACOS_FIELD=deviceStatus.records
NACOS_READ_FALLBACK_TO_SIMULATOR=true

# 底部四个子系统入口。不要再写 localhost；同域部署可只配 SUBSYSTEM_BASE_URL。
SUBSYSTEM_BASE_URL=
SUBSYSTEM_FACE_URL=
SUBSYSTEM_VEHICLE_URL=
SUBSYSTEM_RAIL_URL=
SUBSYSTEM_FIRE_URL=
