# 后端容器环境变量模板。
# 使用方式：
#   cp deploy/backend.env.example deploy/backend.env
#   按你的服务器实际 Nacos 地址修改 deploy/backend.env

PORT=8000

# 场景 1：Nacos 容器和本后端容器在同一个 Docker 网络里，服务名叫 nacos。
NACOS_BASE_URL=http://nacos:8848/nacos

# 场景 2：Nacos 跑在服务器宿主机上，改成：
# NACOS_BASE_URL=http://host.docker.internal:8848/nacos

# 场景 3：Nacos 是另一台服务器，改成：
# NACOS_BASE_URL=http://NACOS服务器IP:8848/nacos

# Nacos 开启鉴权时填写；未开启鉴权时留空。
NACOS_USERNAME=
NACOS_PASSWORD=

# 允许访问后端的前端地址。把 SERVER_IP 改成你的服务器 IP 或域名。
CORS_ALLOWED_ORIGINS=http://SERVER_IP:8000,http://SERVER_IP:9000,http://SERVER_IP:8083

# 发布配置接口密钥；服务器上必须改成强密码。
PUBLISH_API_KEY=change-this-to-a-strong-key

# 启用 Python 模拟设备。
USE_STATE_MACHINE_SIMULATOR=true
SIMULATOR_AUTO_TICK=true
SIMULATOR_TICK_SECONDS=5
