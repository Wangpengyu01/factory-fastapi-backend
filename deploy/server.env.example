# FastAPI 服务监听端口；Dockerfile 当前固定监听 8000。
PORT=8000

# 服务器部署由 docker-compose.server.yml 覆盖为 http://nacos:8848/nacos。
NACOS_BASE_URL=http://nacos:8848/nacos

# 当前服务器版 compose 默认不启用 Nacos 鉴权，并且 Nacos 不直接暴露公网。
NACOS_USERNAME=
NACOS_PASSWORD=

# 允许访问后端的前端地址。把 YOUR_SERVER_IP 改成服务器公网 IP 或域名。
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://localhost:8083,http://YOUR_SERVER_IP:9000,http://YOUR_SERVER_IP:8000

# 发布 Nacos 配置接口的服务端密钥；服务器上必须改成强密码。
PUBLISH_API_KEY=change-this-to-a-strong-key

# 硬件未接入时启用 Python 状态机模拟器。
USE_STATE_MACHINE_SIMULATOR=true
SIMULATOR_AUTO_TICK=true
SIMULATOR_TICK_SECONDS=5
