# FastAPI 服务监听端口；Dockerfile 当前固定监听 8000。
PORT=8000

# 服务器部署由 docker-compose.server.yml 覆盖为 http://nacos:8080。
NACOS_BASE_URL=http://nacos:8080

# docker-compose.server.yml 使用 nacos/nacos-server:latest，对应 Nacos 3.x API。
NACOS_API_VERSION=v3

# 当前服务器版 compose 默认不启用 Nacos 鉴权，并且 Nacos 不直接暴露公网。
NACOS_USERNAME=
NACOS_PASSWORD=

# 允许访问后端的前端地址。把 YOUR_SERVER_IP 改成服务器公网 IP 或域名。
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://localhost:8083,http://YOUR_SERVER_IP:9000,http://YOUR_SERVER_IP:8000

# 发布 Nacos 配置接口的服务端密钥；服务器上必须改成强密码。
PUBLISH_API_KEY=change-this-to-a-strong-key

# 硬件未接入时启用 Python 状态机模拟器。
USE_STATE_MACHINE_SIMULATOR=true
SIMULATOR_AUTO_TICK=true
SIMULATOR_TICK_SECONDS=5

# Python 模拟设备写入 Nacos。
SIMULATOR_NACOS_SYNC_ENABLED=true
SIMULATOR_NACOS_SYNC_INTERVAL_TICKS=1
SIMULATOR_NACOS_DATA_ID=factory.hardware.snapshot.json
SIMULATOR_NACOS_GROUP=DEFAULT_GROUP
SIMULATOR_NACOS_TENANT=

# FastAPI 默认从 Nacos 读取设备状态，再给大屏统一输出。
DEVICE_STATUS_SOURCE=nacos
DEVICE_STATUS_NACOS_DATA_ID=factory.hardware.snapshot.json
DEVICE_STATUS_NACOS_GROUP=DEFAULT_GROUP
DEVICE_STATUS_NACOS_TENANT=
DEVICE_STATUS_NACOS_FIELD=deviceStatus.records
NACOS_READ_FALLBACK_TO_SIMULATOR=true

# 大屏底部四个子系统入口。不要再写 localhost；同域部署可只配 SUBSYSTEM_BASE_URL。
SUBSYSTEM_BASE_URL=
SUBSYSTEM_FACE_URL=
SUBSYSTEM_VEHICLE_URL=
SUBSYSTEM_RAIL_URL=
SUBSYSTEM_FIRE_URL=
